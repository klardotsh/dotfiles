theme = light:rose-pine-dawn,dark:rose-pine
window-theme = system
minimum-contrast = 1.5

background-opacity = 0.915
background-blur = true

cursor-style = bar

# Updating ~/.config/fontconfig files does not sync with "monospace" here;
# fontconfig settings appear to be read once at application start and never
# again. Thus, specify the font explicitly so that (1) MacOS support is
# consistent, and (2) changing fonts gets picked up by Ctrl-Shift-Comma.
font-family = Cascadia Code
font-family = FSD Emoji
font-size = 15

# We always want these.
font-feature = +calt,+liga

# Individual font overrides could go below. For example, for Maple Mono, we'd
# want (to match my old Wezterm config):
# font-feature = +dlig,+cv01,+cv35,+ss02,+ss03,+ss04,+ss05,-ss06,+ss01
